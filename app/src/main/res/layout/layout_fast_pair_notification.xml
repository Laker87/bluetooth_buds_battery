<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingStart="2dp"
    android:paddingEnd="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/fastPairTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/fast_pair_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/splitBatteryRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/leftBatteryItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="62dp"
                android:layout_height="62dp">

                <ImageView
                    android:id="@+id/leftBatteryRing"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:src="@drawable/ring_battery_unified" />

                <TextView
                    android:id="@+id/leftBatteryValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@color/fast_pair_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/left_bud"
                android:textColor="@color/fast_pair_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/caseBatteryItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="68dp"
                android:layout_height="68dp">

                <ImageView
                    android:id="@+id/caseBatteryRing"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@drawable/ring_battery_unified" />

                <TextView
                    android:id="@+id/caseBatteryValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@color/fast_pair_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/caseBatteryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/case_battery"
                android:textColor="@color/fast_pair_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightBatteryItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="62dp"
                android:layout_height="62dp">

                <ImageView
                    android:id="@+id/rightBatteryRing"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:src="@drawable/ring_battery_unified" />

                <TextView
                    android:id="@+id/rightBatteryValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@color/fast_pair_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/right_bud"
                android:textColor="@color/fast_pair_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/singleBatteryRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="51dp"
        android:layout_marginTop="8dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="74dp"
            android:layout_height="74dp">

            <ImageView
                android:id="@+id/singleBatteryRing"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:src="@drawable/ring_battery_unified" />

            <TextView
                android:id="@+id/singleBatteryValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/fast_pair_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/singleBatteryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/main_battery"
            android:textColor="@color/fast_pair_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
